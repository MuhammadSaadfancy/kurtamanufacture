@model IEnumerable<FashionPro.Models.ViewModels.ExpenseListVM>

@{
    ViewData["Title"] = "Expense Management";
    var summary = ViewBag.Summary as FashionPro.Models.ViewModels.ExpenseSummaryVM;
}

<style>
    .stat-card {
        transition: transform 0.2s;
        cursor: pointer;
    }
    .stat-card:hover {
        transform: translateY(-5px);
    }
    .expense-row:hover {
        background-color: #f8f9fa;
    }
</style>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-money-bill-wave text-danger"></i> Expense Management
                            </h4>
                            <p class="text-muted mb-0 mt-1">Track all your daily expenses</p>
                        </div>
                        <div>
                            <a asp-action="Reports" class="btn btn-info me-2">
                                <i class="fas fa-chart-line"></i> Reports
                            </a>
                            <a asp-action="Create" class="btn btn-danger">
                                <i class="fas fa-plus"></i> Add Expense
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card stat-card shadow border-left-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">Today's Expenses</h6>
                            <h3 class="mb-0 text-danger">₨ @summary.TodayTotal.ToString("N0")</h3>
                            <small class="text-muted">@summary.TodayCount transactions</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-calendar-day fa-2x text-muted"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow border-left-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">This Week</h6>
                            <h3 class="mb-0 text-warning">₨ @summary.WeekTotal.ToString("N0")</h3>
                            <small class="text-muted">@summary.WeekCount transactions</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-calendar-week fa-2x text-muted"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow border-left-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted">This Month</h6>
                            <h3 class="mb-0 text-primary">₨ @summary.MonthTotal.ToString("N0")</h3>
                            <small class="text-muted">@summary.MonthCount transactions</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-calendar-alt fa-2x text-muted"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Expenses & Filter -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <i class="fas fa-chart-pie"></i> Top Expenses (This Month)
                </div>
                <div class="card-body">
                    @if (summary.TopExpenses.Any())
                    {
                        @foreach (var item in summary.TopExpenses)
                        {
                            var percentage = (item.TotalAmount / summary.MonthTotal) * 100;
                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <span>@item.ExpenseName</span>
                                    <span class="fw-bold">₨ @item.TotalAmount.ToString("N0")</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-danger" style="width: @percentage%"></div>
                                </div>
                                <small class="text-muted">@item.Count times</small>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center">No expenses this month</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-filter"></i> Filter Expenses
                </div>
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">From Date</label>
                            <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">To Date</label>
                            <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <button type="submit" class="btn btn-info w-100">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div class="col-md-10">
                            <label class="form-label">Search by name/notes</label>
                            <input type="text" name="searchTerm" class="form-control" placeholder="Search..." value="@ViewBag.SearchTerm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <a asp-action="Index" class="btn btn-secondary w-100">
                                <i class="fas fa-sync"></i>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Expenses Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-list"></i> Expense List</span>
                        <span class="badge bg-danger">Total: ₨ @ViewBag.TotalRecords.ToString("N0")</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Date</th>
                                    <th>Expense Name</th>
                                    <th>Amount</th>
                                    <th>Notes</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr class="text-center">
                                        <td colspan="6" class="py-4">
                                            <i class="fas fa-inbox fa-2x text-muted"></i>
                                            <p class="mt-2">No expenses found. Click "Add Expense" to create one.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = (ViewBag.CurrentPage - 1) * 15 + 1;
                                    foreach (var expense in Model)
                                    {
                                        <tr class="expense-row">
                                            <td>@sr</td>
                                            <td class="text-nowrap">@expense.DateDisplay</td>
                                            <td>
                                                <strong>@expense.ExpenseName</strong>
                                            </td>
                                            <td class="text-danger fw-bold">₨ @expense.Amount.ToString("N0")</td>
                                            <td>@(expense.ShortNotes ?? "-")</td>
                                            <td class="text-nowrap">
                                                <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-sm btn-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        sr++;
                                    }
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td colspan="3" class="text-end">Total:</td>
                                    <td class="text-danger">₨ @Model.Sum(x => x.Amount).ToString("N0")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav>
                            <ul class="pagination justify-content-center">
                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { 
                                            page = i, 
                                            fromDate = ViewBag.FromDate, 
                                            toDate = ViewBag.ToDate, 
                                            searchTerm = ViewBag.SearchTerm 
                                        })">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 3000);
        });
    </script>
}