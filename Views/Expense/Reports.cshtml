@{
    ViewData["Title"] = "Expense Reports";
    var dailySummary = ViewBag.DailySummary as dynamic;
    var categorySummary = ViewBag.CategorySummary as List<FashionPro.Models.ViewModels.ExpenseByCategoryVM>;
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-chart-line text-info"></i> Expense Reports
                            </h4>
                            <p class="text-muted mb-0">From @ViewBag.StartDate to @DateTime.Now.ToString("dd-MMM-yyyy")</p>
                        </div>
                        <div>
                            <div class="btn-group">
                                <a asp-action="Reports" asp-route-period="week" class="btn btn-outline-primary @(ViewBag.Period == "week" ? "active" : "")">Week</a>
                                <a asp-action="Reports" asp-route-period="month" class="btn btn-outline-primary @(ViewBag.Period == "month" ? "active" : "")">Month</a>
                                <a asp-action="Reports" asp-route-period="year" class="btn btn-outline-primary @(ViewBag.Period == "year" ? "active" : "")">Year</a>
                            </div>
                            <a asp-action="Index" class="btn btn-secondary ms-2">
                                <i class="fas fa-arrow-left"></i> Back
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow bg-primary text-white">
                <div class="card-body">
                    <h6>Total Expenses</h6>
                    <h2>₨ @ViewBag.TotalExpenses.ToString("N0")</h2>
                    <small>@ViewBag.TotalCount transactions</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-success text-white">
                <div class="card-body">
                    <h6>Average per Day</h6>
                    <h2>₨ @((ViewBag.TotalExpenses / 30).ToString("N0"))</h2>
                    <small>Last 30 days average</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-warning text-white">
                <div class="card-body">
                    <h6>Highest Category</h6>
                    <h5>@(categorySummary.FirstOrDefault()?.ExpenseName ?? "N/A")</h5>
                    <small>₨ @(categorySummary.FirstOrDefault()?.TotalAmount.ToString("N0") ?? "0")</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Daily Summary -->
        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-calendar-day"></i> Daily Summary (Last 30 days)
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-center">Transactions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in dailySummary)
                                {
                                    <tr>
                                        <td>@(((DateTime)item.Date).ToString("dd-MMM-yyyy"))</td>
                                        <td class="text-end text-danger fw-bold">₨ @item.Total.ToString("N0")</td>
                                        <td class="text-center">@item.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Summary -->
        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <i class="fas fa-chart-pie"></i> Expense by Category
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th class="text-end">Total Amount</th>
                                    <th class="text-center">Count</th>
                                    <th class="text-center">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in categorySummary)
                                {
                                    var percentage = (item.TotalAmount / ViewBag.TotalExpenses) * 100;
                                    <tr>
                                        <td>@item.ExpenseName</td>
                                        <td class="text-end text-danger fw-bold">₨ @item.TotalAmount.ToString("N0")</td>
                                        <td class="text-center">@item.Count</td>
                                        <td class="text-center">@percentage.ToString("F1")%</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td>Total</td>
                                    <td class="text-end">₨ @ViewBag.TotalExpenses.ToString("N0")</td>
                                    <td class="text-center">@ViewBag.TotalCount</td>
                                    <td>100%</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>