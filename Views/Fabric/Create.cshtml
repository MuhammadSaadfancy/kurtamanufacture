@model FashionPro.Models.ViewModels.FabricVM

@{
    ViewData["Title"] = "Add Fabric";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add New Fabric Purchase
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">Date</label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PartyId" class="form-label">Supplier</label>
                                <select asp-for="PartyId" asp-items="Model.Suppliers" class="form-select">
                                    <option value="">-- Select Supplier --</option>
                                </select>
                                <span asp-validation-for="PartyId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Variety" class="form-label">Variety</label>
                                <input asp-for="Variety" class="form-control" placeholder="e.g., Lawn, Chiffon, Cotton" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Quantity</label>
                                <div class="row">
                                    <div class="col-6">
                                        <input asp-for="KG" class="form-control" placeholder="KG" />
                                    </div>
                                    <div class="col-6">
                                        <input asp-for="Than" class="form-control" placeholder="Than" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label">Total Amount</label>
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Notes" class="form-label">Notes</label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Back</a>
                            <button type="submit" class="btn btn-primary">Save Fabric Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}