@model FashionPro.Models.Fabric

@{
    ViewData["Title"] = "Delete Fabric";
    var hasPayments = ViewBag.HasPayments ?? false;
    var paymentCount = ViewBag.PaymentCount ?? 0;
    var totalPaid = ViewBag.TotalPaid ?? 0;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-trash-alt"></i> Delete Fabric Record
                    </h4>
                </div>
                <div class="card-body">
                    @if (hasPayments)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Warning!</strong> This fabric record has associated payments!
                            <p class="mb-0 mt-2">
                                Number of payments: <strong>@paymentCount</strong><br />
                                Total amount paid: <strong>₨ @totalPaid.ToString("N0")</strong>
                            </p>
                            <p class="mt-2 mb-0">Deleting this record will also remove all associated payment records!</p>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i>
                            Are you sure you want to delete this fabric record?
                            <p class="mb-0 mt-2">This action cannot be undone.</p>
                        </div>
                    }

                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Fabric Details</h5>
                            <table class="table table-bordered">
                                <tr>
                                    <th style="width: 150px;">Date</th>
                                    <td>@Model.Date.ToString("dd-MMM-yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Supplier</th>
                                    <td><strong>@Model.Party?.PartyName</strong></td>
                                </tr>
                                <tr>
                                    <th>Variety</th>
                                    <td>@(Model.Variety ?? "-")</td>
                                </tr>
                                <tr>
                                    <th>Quantity</th>
                                    <td>
                                        @if (Model.KG.HasValue && Model.KG > 0)
                                        {
                                            <span>@Model.KG KG</span>
                                        }
                                        @if (Model.Than.HasValue && Model.Than > 0)
                                        {
                                            if (Model.KG.HasValue && Model.KG > 0)
                                            {
                                                <span> + </span>
                                            }
                                            <span>@Model.Than Than</span>
                                        }
                                        @if ((!Model.KG.HasValue || Model.KG == 0) && (!Model.Than.HasValue || Model.Than == 0))
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Total Amount</th>
                                    <td class="text-primary fw-bold h5">₨ @Model.Amount.ToString("N0")</td>
                                </tr>
                                @if (hasPayments)
                                {
                                    <tr>
                                        <th>Total Paid</th>
                                        <td class="text-success fw-bold">₨ @totalPaid.ToString("N0")</td>
                                    </tr>
                                    <tr>
                                        <th>Pending Balance</th>
                                        <td class="text-danger fw-bold">₨ @Model.Balance.ToString("N0")</td>
                                    </tr>
                                }
                                <tr>
                                    <th>Status</th>
                                    <td>
                                        @if (Model.Balance == 0)
                                        {
                                            <span class="badge bg-success">Fully Paid</span>
                                        }
                                        else if (Model.Balance < Model.Amount)
                                        {
                                            <span class="badge bg-warning">Partial Payment</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pending</span>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(Model.Notes))
                                {
                                    <tr>
                                        <th>Notes</th>
                                        <td>@Model.Notes</td>
                                    </tr>
                                }
                            </table>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> @(hasPayments ? "Delete Fabric & Payments" : "Delete Fabric")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>