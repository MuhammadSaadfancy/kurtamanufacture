@model FashionPro.Models.ViewModels.FabricVM

@{
    ViewData["Title"] = "Edit Fabric";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Edit Fabric Purchase
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Balance" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">
                                    <i class="fas fa-calendar"></i> Date
                                </label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PartyId" class="form-label">
                                    <i class="fas fa-truck"></i> Supplier
                                </label>
                                <select asp-for="PartyId" asp-items="Model.Suppliers" class="form-select">
                                    <option value="">-- Select Supplier --</option>
                                </select>
                                <span asp-validation-for="PartyId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Variety" class="form-label">
                                    <i class="fas fa-tag"></i> Variety
                                </label>
                                <input asp-for="Variety" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">
                                    <i class="fas fa-weight-hanging"></i> Quantity
                                </label>
                                <div class="row">
                                    <div class="col-6">
                                        <input asp-for="KG" class="form-control" placeholder="KG" />
                                    </div>
                                    <div class="col-6">
                                        <input asp-for="Than" class="form-control" placeholder="Than" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label">
                                    <i class="fas fa-rupee-sign"></i> Total Amount
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">₨</span>
                                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Notes" class="form-label">
                                    <i class="fas fa-sticky-note"></i> Notes
                                </label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        @if (Model.Balance > 0 && Model.Balance < Model.Amount)
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                <strong>Partial Payment Received:</strong> ₨ @(Model.Amount - Model.Balance) already paid.
                                Remaining balance: ₨ @Model.Balance.ToString("N0")
                            </div>
                        }
                        else if (Model.Balance > 0)
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Pending Balance:</strong> ₨ @Model.Balance.ToString("N0") is still pending.
                            </div>
                        }
                        else if (Model.Balance == 0 && Model.Amount > 0)
                        {
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i>
                                <strong>Fully Paid:</strong> This fabric has been fully paid.
                            </div>
                        }

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Fabric
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}