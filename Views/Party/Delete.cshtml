@model FashionPro.Models.Party

@{
    ViewData["Title"] = "Delete Party";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-trash-alt"></i> Delete Party
                    </h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.HasTransactions == true)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> @ViewBag.WarningMessage
                            <p class="mb-0 mt-2">
                                <strong>Note:</strong> The party will be <strong>deactivated</strong> instead of permanently deleted.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this party?
                            <p class="mb-0 mt-2">This action cannot be undone.</p>
                        </div>
                    }

                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Party Information</h5>
                            <table class="table table-bordered">
                                <tr>
                                    <th style="width: 150px;">Party Name</th>
                                    <td>@Model.PartyName</td>
                                </tr>
                                <tr>
                                    <th>Party Type</th>
                                    <td>@Model.PartyType</td>
                                </tr>
                                <tr>
                                    <th>Phone</th>
                                    <td>@(Model.Phone ?? "-")</td>
                                </tr>
                                <tr>
                                    <th>Address</th>
                                    <td>@(Model.Address ?? "-")</td>
                                </tr>
                                <tr>
                                    <th>Current Balance</th>
                                    <td class="@(Model.CurrentBalance >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                        ₨ @Model.CurrentBalance.ToString("N0")
                                    </td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>@(Model.IsActive ? "Active" : "Inactive")</td>
                                </tr>
                                <tr>
                                    <th>Created At</th>
                                    <td>@Model.CreatedAt.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="PartyId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> @(ViewBag.HasTransactions == true ? "Deactivate Party" : "Delete Party")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>