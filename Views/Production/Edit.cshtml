@model FashionPro.Models.ViewModels.ProductionVM

@{
    ViewData["Title"] = "Edit " + ViewBag.ModuleDisplayName;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Edit @ViewBag.ModuleDisplayName
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ModuleType" />
                        <input type="hidden" asp-for="SubType" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">Date</label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PartyId" class="form-label">Worker</label>
                                <select asp-for="PartyId" asp-items="Model.Workers" class="form-select">
                                    <option value="">-- Select Worker --</option>
                                </select>
                                <span asp-validation-for="PartyId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ItemName" class="form-label">Item Name</label>
                                <input asp-for="ItemName" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Quantity</label>
                                <div class="row">
                                    <div class="col-6">
                                        <input asp-for="Dozen" class="form-control" placeholder="Dozen" />
                                    </div>
                                    <div class="col-6">
                                        <input asp-for="Pieces" class="form-control" placeholder="Pieces" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text">₨</span>
                                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Notes" class="form-label">Notes</label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        @if (Model.Balance > 0 && Model.Balance < Model.Amount)
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> Current Balance: ₨ @Model.Balance.ToString("N0") (Partial payment received)
                            </div>
                        }
                        else if (Model.Balance > 0)
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> Current Balance: ₨ @Model.Balance.ToString("N0") (Pending)
                            </div>
                        }

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="@ViewBag.ActiveTab" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Record
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}