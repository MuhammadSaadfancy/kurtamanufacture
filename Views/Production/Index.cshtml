@model IEnumerable<FashionPro.Models.ViewModels.ProductionListVM>

@{
    ViewData["Title"] = ViewBag.ActiveTab + " Records";
    string moduleType = ViewBag.ActiveTab?.ToString() ?? "Production";
    string activeTab = ViewBag.ActiveTab?.ToString() ?? "Production";
    string subType = ViewBag.SubType?.ToString();
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">
                                <i class="fas fa-tshirt"></i> @activeTab Records
                            </h4>
                            <p class="text-muted mb-0">Manage @activeTab transactions</p>
                        </div>
                        <div>
                            <a asp-action="Dashboard" class="btn btn-info me-2">
                                <i class="fas fa-chart-line"></i> Dashboard
                            </a>
                            <a asp-action="Create" asp-route-moduleType="@moduleType" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Add @activeTab
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SubType Navigation for Design/CMT/EndingWork -->
    @if (activeTab == "Design" || activeTab == "CMT" || activeTab == "EndingWork")
    {
        var subTypes = activeTab == "Design" ? new[] { "MRID", "PRINT" } :
                       (activeTab == "CMT" ? new[] { "Shalwar", "Kameez", "Koti" } :
                       new[] { "Cropping", "Press", "Packing" });
        
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-body">
                        <div class="btn-group" role="group">
                            <a asp-action="@activeTab" class="btn btn-outline-primary @(string.IsNullOrEmpty(subType) ? "active" : "")">All</a>
                            @foreach (var sub in subTypes)
                            {
                                <a asp-action="@activeTab" asp-route-subType="@sub"
                                   class="btn btn-outline-primary @(subType == sub ? "active" : "")">@sub</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6>Total Records</h6>
                    <h3>@ViewBag.TotalRecords</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6>Total Amount</h6>
                    <h3>₨ @(ViewBag.TotalAmount?.ToString("N0") ?? "0")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6>Total Pending</h6>
                    <h3>₨ @(ViewBag.TotalBalance?.ToString("N0") ?? "0")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Date</th>
                                    <th>Worker</th>
                                    <th>Item Details</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Balance</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr class="text-center">
                                        <td colspan="8">No records found</td>
                                    </tr>
                                }
                                else
                                {
                                    int sr = (ViewBag.CurrentPage - 1) * 15 + 1;
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@sr++</td>
                                            <td>@item.DateDisplay</td>
                                            <td><strong>@item.PartyName</strong></td>
                                            <td>@item.ItemInfo</td>
                                            <td class="text-end">₨ @item.Amount.ToString("N0")</td>
                                            <td class="text-end @item.BalanceColor fw-bold">₨ @item.Balance.ToString("N0")</td>
                                            <td><span class="badge @item.StatusBadge">@item.Status</span></td>
                                            <td>
                                                <a asp-action="CreatePayment" asp-route-transactionId="@item.Id" class="btn btn-sm btn-success" title="Pay">
                                                    <i class="fas fa-money-bill"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td colspan="4" class="text-end">Total:</td>
                                    <td class="text-end">₨ @Model.Sum(x => x.Amount).ToString("N0")</td>
                                    <td class="text-end text-danger">₨ @Model.Sum(x => x.Balance).ToString("N0")</td>
                                    <td colspan="2"></td>
                                </table>
                            </tfoot>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (totalPages > 1)
                    {
                        <nav>
                            <ul class="pagination justify-content-center">
                                @if (currentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action(activeTab, new { page = currentPage - 1, subType = subType })">
                                            <i class="fas fa-chevron-left"></i> Previous
                                        </a>
                                    </li>
                                }
                                
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action(activeTab, new { page = i, subType = subType })">@i</a>
                                    </li>
                                }
                                
                                @if (currentPage < totalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action(activeTab, new { page = currentPage + 1, subType = subType })">
                                            Next <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>