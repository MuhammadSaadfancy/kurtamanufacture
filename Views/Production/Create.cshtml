@model FashionPro.Models.ViewModels.ProductionVM

@{
    ViewData["Title"] = "Add " + ViewBag.ModuleDisplayName;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add @ViewBag.ModuleDisplayName
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="ModuleType" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">Date</label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PartyId" class="form-label">Worker</label>
                                <select asp-for="PartyId" asp-items="Model.Workers" class="form-select">
                                    <option value="">-- Select Worker --</option>
                                </select>
                                <span asp-validation-for="PartyId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- 🔥 SUBTYPE DROPDOWN - YEH ADD KARO -->
                        @if (Model.SubTypes != null && Model.SubTypes.Any())
                        {
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="SubType" class="form-label">
                                        Sub Type <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="SubType" asp-items="Model.SubTypes" class="form-select">
                                        <option value="">-- Select Sub Type --</option>
                                    </select>
                                    <span asp-validation-for="SubType" class="text-danger"></span>
                                    <small class="text-muted">
                                        @if (ViewBag.ActiveTab == "Design")
                                        {
                                            <span>Select MRID (Embroidery) or PRINT (Printing)</span>
                                        }
                                        else if (ViewBag.ActiveTab == "CMT")
                                        {
                                            <span>Select Shalwar, Kameez, or Koti</span>
                                        }
                                        else if (ViewBag.ActiveTab == "EndingWork")
                                        {
                                            <span>Select Cropping, Press, or Packing</span>
                                        }
                                    </small>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ItemName" class="form-label">Item Name</label>
                                <input asp-for="ItemName" class="form-control" placeholder="e.g., Summer Lawn" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Quantity</label>
                                <div class="row">
                                    <div class="col-6">
                                        <input asp-for="Dozen" class="form-control" placeholder="Dozen" />
                                    </div>
                                    <div class="col-6">
                                        <input asp-for="Pieces" class="form-control" placeholder="Pieces" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text">₨</span>
                                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Notes" class="form-label">Notes</label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="@ViewBag.ActiveTab" class="btn btn-secondary">Back</a>
                            <button type="submit" class="btn btn-primary">Save Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}