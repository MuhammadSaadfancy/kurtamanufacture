@model FashionPro.Models.ViewModels.ProductionPaymentVM

@{
    ViewData["Title"] = "Make Payment to Worker";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-money-bill-wave"></i> Make Payment to Worker
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="CreatePayment" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        @if (!string.IsNullOrEmpty(Model.TransactionReference))
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> @Model.TransactionReference
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">Payment Date</label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PartyId" class="form-label">Worker</label>
                                <select asp-for="PartyId" asp-items="Model.Workers" class="form-select" id="WorkerSelect">
                                    <option value="">-- Select Worker --</option>
                                </select>
                                <span asp-validation-for="PartyId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TransactionId" class="form-label">Select Transaction</label>
                                <select asp-for="TransactionId" asp-items="Model.Transactions" class="form-select" id="TransactionSelect">
                                    <option value="">-- First Select Worker --</option>
                                </select>
                                <span asp-validation-for="TransactionId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label">Payment Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text">₨</span>
                                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
                                <select asp-for="PaymentMethod" asp-items="Model.PaymentMethods" class="form-select" id="PaymentMethodSelect">
                                    <option value="">-- Select Method --</option>
                                </select>
                                <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Notes" class="form-label">Notes</label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                        <!-- 🔥 IMAGE UPLOAD SECTION -->
                        <div class="row" id="ImageUploadSection" style="display: none;">
                            <div class="col-md-12 mb-3">
                                <label asp-for="PaymentImage" class="form-label">Payment Screenshot / Proof</label>
                                <input asp-for="PaymentImage" type="file" class="form-control" accept="image/*" id="PaymentImage" />
                                <small class="text-muted">Upload bank transfer screenshot, EasyPaisa/JazzCash receipt (Optional)</small>
                                <div id="imagePreview" class="mt-2" style="display: none;">
                                    <div class="card" style="max-width: 200px;">
                                        <img id="previewImg" class="card-img-top" src="#" style="max-height: 150px; object-fit: cover;" />
                                        <div class="card-body p-1 text-center">
                                            <button type="button" class="btn btn-sm btn-danger" onclick="clearImage()">Remove</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Payments" class="btn btn-secondary">Back</a>
                            <button type="submit" class="btn btn-success">Record Payment</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        $(document).ready(function() {
            $('#WorkerSelect').change(function() {
                var workerId = $(this).val();
                var $transSelect = $('#TransactionSelect');
                
                if (workerId) {
                    $.ajax({
                        url: '@Url.Action("GetPendingTransactions", "Production")',
                        type: 'GET',
                        data: { partyId: workerId },
                        success: function(data) {
                            $transSelect.empty();
                            $transSelect.append('<option value="">-- Select Transaction --</option>');
                            $.each(data, function(i, item) {
                                $transSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                            });
                        },
                        error: function() {
                            $transSelect.empty();
                            $transSelect.append('<option value="">Error loading transactions</option>');
                        }
                    });
                } else {
                    $transSelect.empty();
                    $transSelect.append('<option value="">-- First Select Worker --</option>');
                }
            });

            // Show/hide image upload based on payment method
            function toggleImageUpload() {
                var method = $('#PaymentMethodSelect').val();
                if (method === 'Bank' || method === 'EasyPaisa' || method === 'JazzCash') {
                    $('#ImageUploadSection').show();
                } else {
                    $('#ImageUploadSection').hide();
                    $('#imagePreview').hide();
                    $('#PaymentImage').val('');
                }
            }
            
            toggleImageUpload();
            $('#PaymentMethodSelect').change(function() { toggleImageUpload(); });
        });
        
        // Image preview
        $('#PaymentImage').change(function() {
            var file = this.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#previewImg').attr('src', e.target.result);
                    $('#imagePreview').show();
                };
                reader.readAsDataURL(file);
            } else {
                $('#imagePreview').hide();
                $('#previewImg').attr('src', '');
            }
        });
        
        function clearImage() {
            $('#PaymentImage').val('');
            $('#imagePreview').hide();
            $('#previewImg').attr('src', '');
        }
    </script>
}