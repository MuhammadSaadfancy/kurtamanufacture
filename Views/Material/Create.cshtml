@model FashionPro.Models.ViewModels.MaterialVM

@{
    ViewData["Title"] = "Add Material";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add New Material
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Date" class="form-label">
                                    <i class="fas fa-calendar"></i> Date
                                </label>
                                <input asp-for="Date" type="date" class="form-control" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="MaterialName" class="form-label">
                                    <i class="fas fa-tag"></i> Material Name
                                </label>
                                <input asp-for="MaterialName" class="form-control" placeholder="e.g., Dhaga, Button, Collar Pati, etc." />
                                <span asp-validation-for="MaterialName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Quantity" class="form-label">
                                    <i class="fas fa-weight-hanging"></i> Quantity
                                </label>
                                <input asp-for="Quantity" class="form-control" type="number" step="0.01" placeholder="0.00" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Unit" class="form-label">
                                    <i class="fas fa-ruler"></i> Unit
                                </label>
                                <select asp-for="Unit" asp-items="Model.Units" class="form-select">
                                    <option value="">-- Select Unit --</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Amount" class="form-label">
                                    <i class="fas fa-rupee-sign"></i> Amount
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">₨</span>
                                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">
                                <i class="fas fa-sticky-note"></i> Notes
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any additional details..."></textarea>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Material
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}